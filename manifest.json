{
  "manifest_version": 3,
  "name": "ETHOS IRB Exporter",
  "description": "Exports ETHOS IRB study SmartForm sections and documents into a structured package.",
  "version": "0.2.2",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ETHOS IRB Exporter",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "scripting", "downloads"],
  "host_permissions": ["https://ethos.swmed.edu/*"]
}
